{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "WEB_APP_URL",
        "NEXT_PUBLIC_WEB_APP_URL",
        "BETTER_AUTH_SECRET",
        "GOOGLE_CLIENT_*",
        "WS_PORT",
        "WS_SECRET",
        "SPOTIFY_*"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "WEB_APP_URL",
        "NEXT_PUBLIC_WEB_APP_URL",
        "WS_PORT",
        "WS_SECRET"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    }
  }
}
