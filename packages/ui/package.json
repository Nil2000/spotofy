{
  "name": "@repo/ui",
  "version": "0.0.0",
  "scripts": {
    "build": "bun run build:styles && bun run build:components",
    "build:styles": "tailwindcss -i ./src/styles/globals.css -o ./dist/globals.css",
    "build:components": "tsc",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/ui/*"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/tailwind-config": "*",
    "@repo/typescript-config": "*",
    "@tailwindcss/cli": "^4.1.5",
    "@types/react": "^19.1.0",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.1.5",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "next-themes": "^0.4.6",
    "shadcn": "^3.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
